{
  "buildCommand": "echo 'static site'",
  "outputDirectory": ".",
  "installCommand": "echo 'no install needed'",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://miniapp.line.me https://liff.line.me"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://starface.km-studio.top/api/:path*" }
  ]
}
